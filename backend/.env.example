# URL do frontend React (para configuração de CORS)
# Em produção, substituir pela URL real da aplicação
AllowedOrigins=http://localhost:5173

# String de conexão com o banco de dados PostgreSQL
# Formato: Host=<host>;Port=<porta>;Database=<banco>;Username=<usuario>;Password=<senha>
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=ControleFermentacaoDb;Username=postgres;Password=postgres
